# Directory for SQLite database and JSONL flat files.
# Defaults to ./data relative to the project root.
# GOVINUITY_META_DIR=/absolute/path/to/your/data

# Directory where Claude Code memory files are stored.
# Defaults to ~/.claude/memory — the standard Claude Code memory location.
# GOVINUITY_MEMORY_DIR=/absolute/path/to/memory

# Directory scanned for JSONL session files during harvest.
# Defaults to ~/.claude/projects (Claude Code session location).
# Override to point at another tool's session export directory.
# GOVINUITY_SESSION_DIR=/absolute/path/to/sessions
